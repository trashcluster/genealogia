{
  "name": "genealogia-functions",
  "version": "1.0.0",
  "description": "Firebase Functions for Genealogia Genealogy App",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "lint": "eslint 'src/**/*'",
    "test": "jest"
  },
  "dependencies": {
    "@google-cloud/firestore": "^7.0.0",
    "@google-cloud/storage": "^7.0.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.0.0",
    "openai": "^4.0.0",
    "@anthropic-ai/sdk": "^0.20.0",
    "axios": "^1.6.0",
    "multer": "^1.4.5",
    "sharp": "^0.33.0",
    "face-api.js": "^0.22.2",
    "pdf-parse": "^1.1.1",
    "tesseract.js": "^5.0.0",
    "node-speech-api": "^0.5.0",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express": "^4.18.0",
    "uuid": "^9.0.0",
    "date-fns": "^3.0.0",
    "lodash": "^4.17.21",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/multer": "^1.4.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@types/lodash": "^4.14.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.25.0",
    "firebase-functions-test": "^3.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": "20"
  },
  "private": true
}
