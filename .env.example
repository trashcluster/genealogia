# Docker image registry and naming configuration
REGISTRY=ghcr.io
IMAGE_NAME=trashcluster/genealogia
VERSION=latest

# PostgreSQL credentials
POSTGRES_PASSWORD=genealogy

# Backend API
SECRET_KEY=your-secret-key-change-in-production
BACKEND_API_KEY=sk_your-backend-api-key

# OpenAI API (Required for ingestion service)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4

# Claude API (Anthropic)
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-sonnet-20240229

# Ollama (Local AI)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama2

# AI Provider Settings
PREFERRED_AI_PROVIDER=openai  # openai, claude, ollama
ENABLE_FALLBACK_PROVIDERS=true

# Telegram Bot (Optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=https://your-domain.com/telegram/webhook

# Frontend
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000

# Face Recognition
FACE_RECOGNITION_ENABLED=true
FACE_RECOGNITION_MODEL=facenet
FACE_SIMILARITY_THRESHOLD=0.6

# Debug mode
DEBUG=False
